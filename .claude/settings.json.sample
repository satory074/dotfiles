{
  "permissions": {
    "allow": [
      "Search(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File ~/.claude/hooks/stop.ps1"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File ~/.claude/hooks/notify.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File ~/.claude/hooks/posttooluse.ps1"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File ~/.claude/hooks/shellcheck.ps1"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File ~/.claude/hooks/failure-log.ps1"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "pwsh -NonInteractive -File ~/.claude/statusline-command.ps1"
  },
  "alwaysThinkingEnabled": true
}
