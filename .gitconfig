[user]
	name = ryouta-satou-rakus
	email = ryouta.satou@rakus.co.jp

[core]
    editor = vim -c "set fenc=utf-8"

[init]
    defaultBranch = main

[fetch]
    prune = true

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true

[diff]
    colorMoved = default

[merge]
    conflictstyle = zdiff3

[branch]
    sort = -committerdate

[column]
    ui = auto

[color]
    ui = auto

[tag]
    sort = version:refname

[rerere]
    enabled = true

[credential "https://github.com"]
    helper =
    helper = !gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !gh auth git-credential

[alias]
    lg = log --oneline --graph --decorate --all
    staged = diff --cached
    undo = reset HEAD~1 --mixed
    aliases = config --get-regexp alias
