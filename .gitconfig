[user]
	name = satory074
	email = satory074@gmail.com

[core]
    editor = vim -c \"set fenc=utf-8\"

[init]
    defaultBranch = main

[fetch]
    prune = true

[pull]
    rebase = true

[push]
    default = simple

[rerere]
    enabled = true

[credential "https://github.com"]
    helper =
    helper = !gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !gh auth git-credential
[push]
	default = current
